erDiagram
    %% =====================================================
    %% KLYRO DATABASE DER
    %% React + NestJS + PostgreSQL
    %% =====================================================
    %% Main design rule:
    %% AI interprets, backend validates, database protects.
    %% =====================================================

    currencies {
        char_3 code PK
        varchar name
        varchar symbol
        boolean is_active
    }

    countries {
        uuid id PK
        char_2 iso_code UK
        varchar name
        char_3 default_currency_code FK
        boolean is_active
    }

    phone_prefixes {
        uuid id PK
        uuid country_id FK
        varchar dial_code
        boolean is_default
        boolean is_active
    }

    languages {
        varchar code PK
        varchar name
        varchar native_name
        boolean is_active
    }

    business_types {
        uuid id PK
        varchar code UK
        varchar name
        text description
        boolean is_active
    }

    payment_providers {
        uuid id PK
        varchar code UK
        varchar name
        boolean is_active
    }

    availability_override_types {
        uuid id PK
        varchar code UK
        varchar name
        boolean blocks_availability
        boolean is_active
    }

    notification_types {
        uuid id PK
        varchar code UK
        varchar name
        text description
        boolean default_enabled
    }

    users {
        uuid id PK
        varchar email UK
        text password_hash
        varchar full_name
        uuid phone_prefix_id FK
        varchar phone_number
        varchar phone_e164
        text avatar_url
        auth_provider_enum auth_provider
        varchar auth_provider_id
        timestamptz email_verified_at
        user_status_enum status
        timestamptz last_login_at
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    businesses {
        uuid id PK
        varchar name
        varchar slug UK
        uuid business_type_id FK
        uuid country_id FK
        char_3 currency_code FK
        varchar default_language_code FK
        varchar timezone
        text logo_url
        text address
        text google_maps_url
        text waze_url
        numeric latitude
        numeric longitude
        uuid phone_prefix_id FK
        varchar phone_number
        varchar phone_e164
        business_status_enum status
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    branches {
        uuid id PK
        uuid business_id FK
        varchar name
        text address
        text google_maps_url
        text waze_url
        numeric latitude
        numeric longitude
        uuid phone_prefix_id FK
        varchar phone_number
        varchar phone_e164
        branch_status_enum status
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    roles {
        uuid id PK
        uuid business_id FK
        varchar code UK
        varchar name
        text description
        boolean is_system_role
        timestamptz created_at
        timestamptz updated_at
    }

    permissions {
        uuid id PK
        varchar code UK
        text description
        timestamptz created_at
    }

    role_permissions {
        uuid role_id PK,FK
        uuid permission_id PK,FK
    }

    business_members {
        uuid business_id PK,FK
        uuid user_id PK,FK
        uuid role_id FK
        member_status_enum status
        timestamptz joined_at
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    business_invitations {
        uuid id PK
        uuid business_id FK
        uuid role_id FK
        varchar email
        text token_hash
        invitation_status_enum status
        uuid invited_by_user_id FK
        timestamptz expires_at
        timestamptz accepted_at
        timestamptz created_at
    }

    business_invite_links {
        uuid id PK
        uuid business_id FK
        uuid role_id FK
        text token_hash
        invite_link_status_enum status
        integer max_uses
        integer uses_count
        timestamptz expires_at
        uuid created_by_user_id FK
        timestamptz created_at
        timestamptz updated_at
    }

    business_invite_link_uses {
        uuid invite_link_id PK,FK
        uuid user_id PK,FK
        timestamptz used_at
    }

    workers {
        uuid id PK
        uuid business_id FK
        uuid user_id FK
        varchar first_name
        varchar last_name
        varchar public_name
        varchar email
        uuid phone_prefix_id FK
        varchar phone_number
        varchar phone_e164
        text bio
        varchar color
        worker_status_enum status
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    worker_aliases {
        uuid id PK
        uuid business_id FK
        uuid worker_id FK
        varchar alias
        varchar normalized_alias
        timestamptz created_at
    }

    worker_branches {
        uuid worker_id PK,FK
        uuid branch_id PK,FK
        uuid business_id FK
        boolean is_primary
        timestamptz created_at
    }

    services {
        uuid id PK
        uuid business_id FK
        varchar name
        text description
        numeric base_price
        integer duration_minutes
        integer buffer_before_minutes
        integer buffer_after_minutes
        service_status_enum status
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    service_aliases {
        uuid id PK
        uuid business_id FK
        uuid service_id FK
        varchar alias
        varchar normalized_alias
        timestamptz created_at
    }

    worker_services {
        uuid worker_id PK,FK
        uuid service_id PK,FK
        uuid business_id FK
        numeric price_override
        integer duration_override_minutes
        boolean is_active
        timestamptz created_at
        timestamptz updated_at
    }

    branch_services {
        uuid branch_id PK,FK
        uuid service_id PK,FK
        uuid business_id FK
        boolean is_active
        timestamptz created_at
    }

    worker_schedules {
        uuid id PK
        uuid business_id FK
        uuid worker_id FK
        uuid branch_id FK
        smallint day_of_week
        time start_time
        time end_time
        boolean is_active
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    worker_availability_overrides {
        uuid id PK
        uuid business_id FK
        uuid worker_id FK
        uuid branch_id FK
        uuid override_type_id FK
        timestamptz start_at
        timestamptz end_at
        text reason
        source_enum source
        uuid created_by_user_id FK
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    clients {
        uuid id PK
        uuid business_id FK
        uuid default_branch_id FK
        varchar name
        uuid phone_prefix_id FK
        varchar phone_number
        varchar phone_e164 UK
        varchar email
        source_enum source
        text notes
        client_status_enum status
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    client_branches {
        uuid client_id PK,FK
        uuid branch_id PK,FK
        uuid business_id FK
        timestamptz first_seen_at
        timestamptz last_seen_at
    }

    conversations {
        uuid id PK
        uuid business_id FK
        uuid branch_id FK
        uuid client_id FK
        message_channel_enum channel
        conversation_status_enum status
        boolean ai_enabled
        jsonb state
        text summary
        timestamptz last_message_at
        timestamptz last_processed_at
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    messages {
        uuid id PK
        uuid business_id FK
        uuid branch_id FK
        uuid conversation_id FK
        uuid client_id FK
        message_role_enum role
        message_channel_enum channel
        message_type_enum message_type
        text content
        varchar external_message_id UK
        message_status_enum status
        jsonb metadata
        timestamptz created_at
        timestamptz processed_at
        timestamptz deleted_at
    }

    message_attachments {
        uuid id PK
        uuid message_id FK
        attachment_type_enum media_type
        varchar provider
        varchar external_media_id
        text file_url
        varchar mime_type
        integer file_size_bytes
        text transcription
        jsonb metadata
        timestamptz created_at
    }

    appointments {
        uuid id PK
        uuid business_id FK
        uuid branch_id FK
        uuid client_id FK
        uuid worker_id FK
        uuid service_id FK
        uuid conversation_id FK
        timestamptz start_at
        timestamptz end_at
        appointment_status_enum status
        numeric quoted_price
        char_3 currency_code FK
        text notes
        source_enum source
        created_by_type_enum created_by_type
        uuid created_by_user_id FK
        timestamptz confirmed_at
        timestamptz cancelled_at
        text cancel_reason
        timestamptz expires_at
        varchar idempotency_key UK
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    appointment_events {
        uuid id PK
        uuid appointment_id FK
        uuid business_id FK
        appointment_event_type_enum event_type
        jsonb old_values
        jsonb new_values
        created_by_type_enum created_by_type
        uuid created_by_user_id FK
        text reason
        timestamptz created_at
    }

    message_templates {
        uuid id PK
        uuid business_id FK
        template_provider_enum provider
        template_type_enum type
        varchar name
        varchar external_template_name
        varchar language_code FK
        varchar subject
        text body
        template_status_enum status
        jsonb variables_schema
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    business_ai_settings {
        uuid id PK
        uuid business_id FK,UK
        varchar ai_name
        varchar default_language_code FK
        ai_tone_enum tone
        text business_context
        uuid welcome_template_id FK
        uuid handoff_template_id FK
        boolean is_enabled
        integer max_tool_calls
        tool_overflow_behavior_enum tool_call_overflow_behavior
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    business_whatsapp_accounts {
        uuid id PK
        uuid business_id FK
        uuid branch_id FK
        varchar waba_id
        varchar phone_number_id UK
        varchar display_phone_number
        uuid phone_prefix_id FK
        varchar phone_number
        varchar phone_e164
        text access_token_encrypted
        whatsapp_account_status_enum status
        timestamptz connected_at
        timestamptz disconnected_at
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    calendar_connections {
        uuid id PK
        uuid business_id FK
        uuid branch_id FK
        uuid worker_id FK
        calendar_provider_enum provider
        varchar external_calendar_id
        text access_token_encrypted
        text refresh_token_encrypted
        calendar_connection_status_enum status
        timestamptz last_synced_at
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    appointment_calendar_events {
        uuid id PK
        uuid business_id FK
        uuid branch_id FK
        uuid appointment_id FK
        uuid calendar_connection_id FK
        varchar external_event_id
        calendar_event_status_enum status
        timestamptz last_synced_at
        jsonb metadata
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    reminders {
        uuid id PK
        uuid business_id FK
        uuid branch_id FK
        uuid appointment_id FK
        uuid client_id FK
        message_channel_enum channel
        timestamptz scheduled_for
        timestamptz sent_at
        reminder_status_enum status
        uuid template_id FK
        text error_message
        timestamptz created_at
        timestamptz updated_at
        timestamptz deleted_at
    }

    notifications {
        uuid id PK
        uuid business_id FK
        uuid branch_id FK
        uuid user_id FK
        uuid notification_type_id FK
        varchar title
        text body
        notification_status_enum status
        entity_type_enum related_entity_type
        uuid related_entity_id
        timestamptz created_at
        timestamptz read_at
    }

    notification_preferences {
        uuid user_id PK,FK
        uuid business_id PK,FK
        uuid notification_type_id PK,FK
        notification_channel_enum channel PK
        boolean is_enabled
        timestamptz created_at
        timestamptz updated_at
    }

    plans {
        uuid id PK
        varchar code UK
        varchar name
        text description
        numeric monthly_price
        char_3 currency_code FK
        integer max_workers
        integer max_branches
        integer max_conversations_per_month
        integer max_ai_messages_per_month
        integer max_input_tokens_per_month
        integer max_output_tokens_per_month
        boolean has_google_calendar
        boolean has_whatsapp
        boolean has_reminders
        boolean is_active
        timestamptz created_at
        timestamptz updated_at
    }

    business_subscriptions {
        uuid id PK
        uuid business_id FK
        uuid plan_id FK
        uuid payment_provider_id FK
        varchar provider_customer_id
        varchar provider_subscription_id
        subscription_status_enum status
        timestamptz current_period_start
        timestamptz current_period_end
        timestamptz cancelled_at
        timestamptz created_at
        timestamptz updated_at
    }

    usage_counters {
        uuid id PK
        uuid business_id FK
        date period_start
        date period_end
        integer conversations_count
        integer messages_count
        integer ai_requests_count
        integer input_tokens
        integer output_tokens
        integer appointments_created_count
        integer whatsapp_messages_sent_count
        timestamptz created_at
        timestamptz updated_at
    }

    audit_logs {
        uuid id PK
        uuid business_id FK
        uuid branch_id FK
        uuid user_id FK
        uuid client_id FK
        uuid conversation_id FK
        varchar action
        entity_type_enum entity_type
        uuid entity_id
        jsonb old_values
        jsonb new_values
        jsonb metadata
        timestamptz created_at
    }

